# QuoteAssist — environment variable reference.
# Copy to .env and fill in real values. Never commit .env to version control.
# The docker-compose.yml already embeds dev defaults; this file documents what
# each variable means and what's required in staging/prod.

# ── Database ────────────────────────────────────────────────────────────────────
# Full Ecto/Postgres connection URL.
# Format: ecto://USER:PASS@HOST/DATABASE
# Dev default (via docker-compose): ecto://postgres:postgres@db/quote_assist_dev
DATABASE_URL=ecto://postgres:postgres@localhost/quote_assist_dev

# ── Phoenix ─────────────────────────────────────────────────────────────────────
# Secret used to sign/encrypt cookies and tokens. Generate with: mix phx.gen.secret
# REQUIRED in staging and prod. Dev uses a hard-coded value from config/dev.exs.
SECRET_KEY_BASE=

# Public hostname for the platform (no trailing slash, no port in prod).
# Dev: localhost — staging/prod: quoteassist.mytechbytes.in
PHX_HOST=localhost

# Deployment environment tag shown in the platform footer: dev | staging | prod.
# Unset on a :prod release falls back to "prod"; set explicitly on staging.
DEPLOY_ENV=staging

# HTTP port the release listens on (default: 4000).
PORT=4000

# Set to "true" to start the Phoenix server when running as a Mix release.
# Not needed when running with `mix phx.server`.
PHX_SERVER=true

# ── AI service ──────────────────────────────────────────────────────────────────
# Internal URL of the Python/FastAPI AI service.
# Dev default (via docker-compose): http://ai-service:8000
# Local host dev: http://localhost:8000
AI_SERVICE_URL=http://localhost:8000

# ── Redis ───────────────────────────────────────────────────────────────────────
# Used for rate limiting and job queues (added in a later release).
REDIS_URL=redis://localhost:6379

# ── Mailer ──────────────────────────────────────────────────────────────────────
# In dev, Swoosh local adapter stores emails in memory (/dev/mailbox preview).
# In staging/prod, configure your transactional email provider here.
# Example for Mailgun:
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# ── DNS / clustering ─────────────────────────────────────────────────────────────
# Optional: Erlang DNS cluster query for multi-node Fly/K8s deploys.
# Leave blank for single-node and local dev.
DNS_CLUSTER_QUERY=

# ── Misc ─────────────────────────────────────────────────────────────────────────
# IPv6 support for the DB socket (set to "true" on hosts that need it).
ECTO_IPV6=false
