# Copy to .env for local development. No real secrets in this file.

# --- Platform (Elixir/Phoenix) ---
DATABASE_URL=ecto://postgres:postgres@localhost:5432/quote_assist_dev
REDIS_URL=redis://localhost:6379
AI_SERVICE_URL=http://localhost:8000
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
PHX_HOST=localhost

# --- AI service (Python) ---
AI_DEFAULT_MODEL=claude-haiku
ANTHROPIC_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# --- Outlook add-in (Vite, prefixed VITE_) ---
VITE_API_BASE=https://localhost:4000
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# --- Pricing source (per tenant; example) ---
PRICING_API_URL=
PRICING_API_OAUTH_SECRET=
