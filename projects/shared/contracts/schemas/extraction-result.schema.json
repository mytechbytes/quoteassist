{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quoteassist.dev/contracts/extraction-result.schema.json",
  "title": "ExtractionResult",
  "description": "AI service /extract response (§9.1). Validated against the active schema; unvalidated output is rejected.",
  "type": "object",
  "additionalProperties": false,
  "required": ["correlation_id", "fields", "overall_confidence", "prompt_version", "model_version"],
  "properties": {
    "correlation_id": { "type": "string" },
    "fields": {
      "type": "object",
      "description": "Extracted structured requirement; shape governed by the active extraction schema.",
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "description": "Per-item breakdown (e.g. multiple itineraries/line-items), each with an assigned item id.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["item_id"],
        "properties": {
          "item_id": { "type": "string" }
        }
      },
      "default": []
    },
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_breakdown": {
      "type": "object",
      "description": "Per-field confidence, auditable.",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "ambiguous_fields": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "prompt_version": { "type": "string" },
    "schema_version": { "type": "string" },
    "ai_provider": {
      "type": "string",
      "description": "e.g. claude-haiku, claude-sonnet, gpt-4o, local."
    },
    "model_version": { "type": "string" },
    "latency_ms": { "type": "integer", "minimum": 0 }
  }
}
