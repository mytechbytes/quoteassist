{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quoteassist.dev/contracts/pricing-request.schema.json",
  "title": "PricingRequest",
  "description": "Built by the pricing orchestrator from a validated requirement and sent to a PricingSource adapter (§M6).",
  "type": "object",
  "additionalProperties": false,
  "required": ["correlation_id", "tenant_id", "category", "currency", "items"],
  "properties": {
    "correlation_id": { "type": "string" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "category": {
      "type": "string",
      "description": "Category slug (stable id), e.g. flights, hotels, packages."
    },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["item_id", "type"],
        "properties": {
          "item_id": { "type": "string" },
          "type": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1, "default": 1 },
          "attributes": {
            "type": "object",
            "description": "Item-specific fields (origin/destination/dates/pax, sku, etc.).",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
