# Keep the Docker build context small and reproducible. The Dockerfile copies
# only mix.exs/mix.lock, config, priv, lib, and assets — everything below is
# either rebuilt in the image or irrelevant to a prod release.

# Build artifacts & deps (rebuilt inside the image)
_build/
deps/
.fetch
*.ez
erl_crash.dump

# Coverage / docs / tarballs
cover/
/doc/
*.tar

# Locally built/digested assets (regenerated by `mix assets.deploy`)
priv/static/assets/
priv/static/cache_manifest.json
assets/node_modules/

# Tests aren't needed for a prod release build
test/

# Tooling, VCS, editor, OS noise
.git/
.gitignore
.elixir_ls/
.elixir-tools/
.idea/
.vscode/
.DS_Store
tmp/
*.log

# Env / secrets must never enter an image layer
.env
.env.*
